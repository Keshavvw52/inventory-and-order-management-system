# ──────────────────────────────────────────────
# Application Settings
# ──────────────────────────────────────────────
APP_NAME="Inventory & Order Management System"
DEBUG=False

# ──────────────────────────────────────────────
# Database
# You can either set DATABASE_URL directly or use the POSTGRES_* variables below.
# Render: Use the internal connection string from the managed DB dashboard.
# Local:  postgresql://postgres:<password>@localhost:5432/inventory_db
# ──────────────────────────────────────────────
DATABASE_URL=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=inventory_db
POSTGRES_ADMIN_DB=postgres

# ──────────────────────────────────────────────
# CORS — comma-separated list of allowed origins
# ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://localhost:3000
